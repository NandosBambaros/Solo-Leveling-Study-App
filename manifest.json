{
  "manifest_version": 3,
  "name": "Hunter's System",
  "version": "1.0.0",
  "description": "IBDP Quest & Study Tracker",
  "icons": {
    "16": "favicon.png",
    "48": "favicon.png",
    "128": "favicon.png"
  },
  "action": {
    "default_title": "Hunter's System"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "offline_enabled": true
}
